# Server-only OpenAI key. TEST=1 skips real OpenAI calls and returns src/test/fixtures/concept.png.
OPENAI_API_KEY=sk-your-key

# Convex deployment. The app includes a local TEST fallback so pnpm verify does not require a deployment.
CONVEX_DEPLOYMENT=dev:your-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional: force local API storage for demos/tests.
NEXT_PUBLIC_POPCA_LOCAL=1
