{
  "name": "popca",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "env TEST=1 NEXT_PUBLIC_POPCA_LOCAL=1 sh -c \"pnpm build && playwright test\"",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm e2e"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "convex": "^1.39.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "next": "15.5.18",
    "openai": "^6.39.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0",
    "wasee-gallery": "^0.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "convex-test": "^0.0.53",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "ws": ">=8.20.1"
    }
  }
}
